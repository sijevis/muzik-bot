# ==========================================
# DJ AI - Environment Variables
# ==========================================

# Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Last.fm API (https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# YouTube Data API (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# Firebase Configuration (https://console.firebase.google.com)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
# Service Account JSON dosyasinin yolu veya Application Default Credentials kullanin
# Ornek: FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Server Configuration
PORT=5000
FLASK_DEBUG=false